    macros {
        KB_EN: KB_EN {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LC(LA(NUMBER_6))>,
                <&macro_wait_time 25>,
                <&to 0>,
                <&macro_wait_time 25>;

            label = "KB_EN";
        };

