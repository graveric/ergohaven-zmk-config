        arcane_left_en: arcane_left_en {
            compatible = "zmk,behavior-hold-tap";
            label = "ARCANE_LEFT_EN";
            bindings = <&kp>, <&arc_en_left>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "hold-preferred";
        };

        arcane_left_ru: arcane_left_ru {
            compatible = "zmk,behavior-hold-tap";
            label = "ARCANE_LEFT_RU";
            bindings = <&kp>, <&arc_ru_left>;

