            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp SPACE &kp RA(MINUS) &kp SPACE>;
            label = "EMDASH_SPACED";
        };

        spaced_ru_emdash: spaced_ru_emdash {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&KB_EN>,
                <&macro_wait_time 50>,
                <&kp SPACE>,
                <&macro_wait_time 5>,
                <&kp LS(LC(U))>,
                <&macro_wait_time 10>,
                <&kp N2 &kp N0 &kp N1 &kp N4 &kp ENTER>,
                <&macro_wait_time 30>,
                <&KB_RU>,
                <&macro_wait_time 5>,
                <&kp SPACE>;

            label = "SPACED_RU_EMDASH";
        };

        spaced_en_emdash: spaced_en_emdash {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp SPACE>,
                <&macro_wait_time 10>,
                <&kp LS(LC(U))>,
                <&macro_wait_time 10>,
                <&kp N2 &kp N0 &kp N1 &kp N4 &kp ENTER>,
                <&macro_wait_time 10>,
                <&kp SPACE>;

            label = "SPACED_EN_EMDASH";
        };

        gm_dot_space_shift: gm_dot_space_shift {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp RA(LS(C)) &kp SPACE &sk LSHFT>;
            label = "GM_DOT_SPACE_SHIFT";
        };

        clean_mods: clean_mods {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings 
                = <&macro_release &mo 2> // 1. Выключаем слой 2
                , <&macro_release &kp LSHFT &kp LCTRL &kp LALT &kp LGUI>; // 2. Чистим моды
        };
    };

    keymap {
        compatible = "zmk,keymap";

        en_base {
            label = "BASE";
            bindings = <
  &kp J  &kp Y      &kp A      &kp U         &gr_minus                            &kp Q    &kp G      &kp N  &kp F  &kp K
  &kp H  &kp I      &kp O      &kp E         &gr_dot_en                           &kp P    &kp D      &kp R  &kp S  &kp M
  &kp X  &gr_under  &gr_quote  &gr_comma_en  &gr_slash                            &kp B    &kp C      &kp L  &kp W  &kp V
                               &kp LSHFT     &lt 2 SPACE  &lt 7 TAB    &lt 4 ESC  &lt 3 T  &kp RSHFT
            >;
        };

        ru {
            bindings = <
  &kp A  &kp E  &kp F  &kp DOT       &gr_minus                     &kp I      &kp V   &kp Y  &kp R  &kp P
  &kp Z  &kp B  &kp J  &kp T         &gr_dot_ru                    &kp U      &kp N   &kp H  &kp D  &kp X
  &kp Q  &kp S  &kp M  &gr_comma_ru  &kp GRAVE                     &kp COMMA  &kp L   &kp K  &kp G  &kp SEMICOLON
                       &trans        &trans      &trans    &trans  &lt 3 C    &trans
            >;
        };

        nav_layer {
            label = "NAVI";
            bindings = <
  &swapper_win     &kp LS(HOME)            &kp LS(UP)               &kp LS(END)    &kp LC(LS(HOME))                       &kp LC(HOME)  &kp HOME        &kp UP_ARROW       &kp END          &kp PAGE_UP
  &lt 5 LS(LC(K))  &kp LS(LEFT)            &kp LS(DOWN)             &kp LS(RIGHT)  &kp LS(LC(END))                        &kp LC(END)   &kp LEFT_ARROW  &kp DOWN_ARROW     &kp RIGHT_ARROW  &lt 5 PG_DN
  &mo 6            &cut_string_alt LALT 0  &line_down_ctrl LCTRL 0  &kp DEL        &tabber                                &kp ENTER     &kp BACKSPACE   &kp LC(BACKSPACE)  &kp INS          &lt 6 PRINTSCREEN
                                                                    &trans         &clean_mods            &trans    &kp LCTRL  &mo 11        &kp LSHFT
            >;
        };

        Sym1 {
            bindings = <
  &kp BACKSLASH     &kp RA(E)  &kp RA(F)  &kp RA(COMMA)         &kp RA(DOT)                                 &kp LS(NUMBER_1)  &kp RA(NUMBER_1)  &kp RA(Y)       &kp RA(R)         &kp RA(BACKSLASH)
  &kp RA(H)         &kp RA(B)  &kp RA(J)  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS                       &kp RA(U)         &kp LS(RA(N8))    &kp LS(RA(N7))  &kp RA(N7)        &kp LS(N5)
  &kp RA(NUMBER_6)  &kp RA(S)  &kp RA(L)  &kp EQUAL             &kp RA(LS(L))                               &kp LS(NUMBER_3)  &kp RA(NUMBER_4)  &emdash_spaced  &kp LS(NUMBER_2)  &kp LS(RA(GRAVE))
                                          &kp LSHFT             &lt 11 SPACE           &kp LCTRL    &trans  &trans            &trans
            >;
        };

        Sym2 {
            label = "SYM2";
            bindings = <
  &kp F10            &kp F9        &kp F4         &kp F3         &gr_minus                        &gr_sqp            &kp N7               &kp N8               &kp N9              &kp RA(NUMBER_3)
  &hml LEFT_GUI F11  &hml LALT F8  &hml LCTRL F5  &hml LSHFT F2  &kp RA(LS(C))                    &kp N0             &hmr RSHFT NUMBER_1  &hmr LCTRL NUMBER_2  &hmr LALT NUMBER_3  &hmr LEFT_GUI PERCENT
  &kp F12            &kp F7        &kp F6         &kp F1         &gr_slash                        &kp RA(SEMICOLON)  &kp NUMBER_4         &kp N5               &kp NUMBER_6        &kp LS(RA(N5))
                                                  &trans         &trans         &trans    &trans  &trans             &trans
            >;
        };

        adj {
            label = "adj";
            bindings = <
  &bootloader   &bt BT_SEL 3  &bt BT_SEL 2  &bt BT_SEL 1      &bt BT_SEL 0                         &kp C_MUTE       &kp F3  &kp F4  &kp F9  &kp F10
  &kp LEFT_GUI  &kp LALT      &kp LCTRL     &kp LSHFT         &kp C_VOLUME_DOWN                    &kp C_VOLUME_UP  &kp F2  &kp F5  &kp F8  &kp F11
  &bt BT_CLR    &out OUT_BLE  &out OUT_USB  &kp C_PLAY_PAUSE  &kp C_PREV                           &kp C_NEXT       &kp F1  &kp F6  &kp F7  &kp F12
                                            &trans            &trans             &trans    &trans  &trans           &trans
            >;

            display-name = "Adjust";
        };

        khronkite {
            label = "khrnkt";
            bindings = <
  &kp LG(LA(Q))  &kp LA(LG(O))  &kp LS(LG(K))  &kp LA(LG(R))  &kp LA(LG(T))                       &kp LG(F)             &kp LS(LA(F8))  &kp LS(LA(F9))  &kp LS(LA(F10))  &kp LS(LA(F11))
  &kp LA(LG(F))  &kp LS(LG(H))  &kp LS(LG(J))  &kp LS(LG(L))  &kp LA(LG(Y))                       &kp LS(LG(UP_ARROW))  &kp LC(F1)      &kp LC(F2)      &kp LC(F3)       &kp LC(F4)
  &trans         &kp LC(LG(K))  &kp LC(LG(H))  &kp LG(LC(L))  &kp LC(LG(J))                       &kp LS(LG(DOWN))      &kp LG(M)       &kp LA(F3)      &kp LG(LC(A))    &trans
                                               &kp LG(ENTER)  &trans         &kp LG(J)    &trans  &trans                &kp LG(ENTER)
            >;
        };

        Shortcuts {
            bindings = <
  &kp LC(W)      &kp LC(Q)  &kp LC(LS(I))  &kp LS(LC(R))  &kp LC(T)                      &kp LC(MINUS)  &kp LC(D)  &kp LC(N)          &kp LS(LC(M))  &kp LC(MINUS)
  &kp LS(LC(K))  &kp LC(L)  &kp LC(S)      &kp LC(A)      &kp LC(F)                      &kp LC(EQUAL)  &kp LC(P)  &kp LS(LA(LC(E)))  &kp LC(O)      &kp LC(PLUS)
  &kp LA(F8)     &kp LA(Z)  &kp LC(G)      &kp LC(R)      &kp LC(H)                      &kp LC(B)      &kp LC(I)  &kp LC(U)          &kp LS(LC(X))  &kp LS(DEL)
                                           &trans         &trans     &trans    &kp LALT  &kp LCTRL      &kp LSHFT
            >;
        };

        Mouse {
            bindings = <
  &trans        &sk LC(LALT)  &sk LS(LA(LCTRL))  &sk LS(LCTRL)  &trans                    &msc SCRL_UP    &mkp LCLK       &mmv MOVE_UP    &mkp RCLK        &trans
  &kp LEFT_GUI  &kp LALT      &sk LCTRL          &sk LSHFT      &trans                    &msc SCRL_DOWN  &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &trans
  &mo 8         &trans        &trans             &trans         &trans                    &trans          &msc SCRL_LEFT  &mkp MCLK       &msc SCRL_RIGHT  &trans
                                                 &trans         &trans  &trans    &trans  &trans          &trans
            >;
        };

        Fadein {
            bindings = <
  &trans  &trans  &trans  &trans     &trans                                 &trans          &trans          &trans  &trans  &trans
  &trans  &trans  &trans  &en_tenge  &en_mngt                               &en_emdash      &en_endash      &trans  &trans  &trans
  &trans  &trans  &trans  &en_quex   &trans                                 &en_hyperminus  &en_figuredash  &trans  &trans  &trans
                          &en_rdq    &en_ldq   &spaced_en_emdash    &trans  &trans          &trans
            >;
        };

        Fadeinru {
            bindings = <
  &trans  &trans  &trans  &trans     &trans                                 &trans          &trans          &trans  &trans  &trans
  &trans  &trans  &trans  &ru_tenge  &ru_mngt                               &ru_emdash      &ru_endash      &trans  &trans  &trans
  &trans  &trans  &trans  &ru_quex   &trans                                 &ru_hypenminus  &ru_figuredash  &trans  &trans  &trans
                          &ru_rdq    &ru_ldq   &spaced_ru_emdash    &trans  &trans          &trans
            >;
        };

        unicode {
            bindings = <
  &kp LALT       &kp RA(N8)  &kp RA(G)  &kp RA(X)  &kp RA(I)                               &kp RA(D)      &kp RA(A)  &kp RA(N)              &kp RA(M)          &kp RA(V)
  &kp RA(LS(M))  &kp RA(B)   &kp RA(C)  &kp LSHFT  &kp RS(RA(NUMBER_6))                    &kp RA(MINUS)  &kp LSHFT  &kp RA(LS(SEMICOLON))  &kp RA(LS(MINUS))  &kp RA(N5)
  &kp LGUI       &kp RA(Q)   &kp RA(O)  &kp RA(Z)  &kp RA(LS(NUMBER_3))                    &kp ENTER      &kp BSPC   &kp DEL                &kp RA(SLASH)      &kp RA(LS(EQUAL))
                                        &trans     &trans                &trans    &trans  &trans         &trans
            >;
        };
    };
};
